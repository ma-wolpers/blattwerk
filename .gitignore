# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Test and tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Coverage and build artifacts
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/

# Logs and temp files
*.log
*.tmp

# Environment files
.env
.env.*

# VS Code workspace files (allow shared project config)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# VS Code extension build artifacts
node_modules/
*.vsix
vscode-extension/blattwerk-language/out/

# OS metadata
desktop.ini
Thumbs.db
.DS_Store

# Local history
.history/

# Local app user state (never commit)
app/storage/.state/*.json